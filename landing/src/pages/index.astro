---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Yhtua — Secure 2FA Token Manager">
  <!-- Nav -->
  <nav class="fixed top-0 inset-x-0 z-40 border-b border-border bg-base/80 backdrop-blur-xl backdrop-saturate-150">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2.5 group">
        <img src="/Yhtua/icon.png" alt="Yhtua" class="w-7 h-7 rounded-lg" />
        <span class="text-sm font-bold tracking-tight text-fg">Yhtua</span>
      </a>
      <div class="hidden sm:flex items-center gap-6">
        <a href="#features" class="text-[13px] text-fg-muted hover:text-fg transition-colors">Features</a>
        <a href="#security" class="text-[13px] text-fg-muted hover:text-fg transition-colors">Security</a>
        <a href="#download" class="text-[13px] text-fg-muted hover:text-fg transition-colors">Download</a>
      </div>
      <a
        href="https://github.com/iiAku/Yhtua/releases/latest"
        class="text-[13px] font-semibold px-4 py-1.5 rounded-lg bg-amber text-base hover:bg-amber-dim transition-colors"
      >
        Download
      </a>
    </div>
  </nav>

  <!-- Hero — split layout with animated TOTP mockup -->
  <section class="relative min-h-screen flex items-center pt-14">
    <!-- Background texture -->
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-1/3 right-0 w-[500px] h-[500px] opacity-100" style="background: radial-gradient(circle, rgba(212,165,74,0.04) 0%, transparent 60%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 w-full grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: copy -->
      <div>
        <div class="animate-fade-in">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald/20 bg-emerald-glow mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald" style="animation: pulse-soft 2s ease-in-out infinite;"></span>
            <span class="text-[13px] font-medium text-emerald">v2.7.0 — Multi-device sync with tombstones</span>
          </div>
        </div>

        <h1 class="animate-fade-in delay-1 text-[clamp(2.25rem,5vw,3.5rem)] font-extrabold tracking-[-0.03em] leading-[1.1] mb-6">
          <span class="text-fg">Two factors.</span><br />
          <span class="bg-gradient-to-r from-amber via-amber-dim to-emerald bg-clip-text text-transparent">Zero trust required.</span>
        </h1>

        <p class="animate-fade-in delay-2 text-[17px] text-fg-muted leading-relaxed mb-10 max-w-lg">
          Open-source 2FA token manager with AES-256 encryption and OS keychain integration. No cloud accounts. No tracking.
        </p>

        <div class="animate-fade-in delay-3 flex flex-col sm:flex-row items-start gap-3">
          <a
            href="https://github.com/iiAku/Yhtua/releases/latest"
            class="group inline-flex items-center gap-2.5 px-6 py-3 rounded-xl bg-amber text-base font-semibold text-[15px] hover:bg-amber-dim transition-all shadow-lg shadow-amber/10"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            Download for free
            <svg class="w-3.5 h-3.5 opacity-50 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </a>
          <a
            href="https://github.com/iiAku/Yhtua"
            class="inline-flex items-center gap-2.5 px-6 py-3 rounded-xl border border-border text-fg-muted font-semibold text-[15px] hover:bg-elevated hover:border-border-hover hover:text-fg transition-all"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
            View source
          </a>
        </div>

        <!-- Platform tags -->
        <div class="animate-fade-in delay-4 flex items-center gap-4 mt-8 text-[13px] text-fg-subtle font-medium">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M22 17.607c-.786 2.28-3.139 6.317-5.563 6.361-1.608.031-2.125-.953-3.963-.953-1.837 0-2.412.923-3.932.983-2.572.099-6.542-5.827-6.542-10.995 0-4.747 3.308-7.1 6.198-7.143 1.55-.028 3.014 1.045 3.959 1.045.949 0 2.727-1.29 4.596-1.101.782.033 2.979.315 4.389 2.377-3.741 2.442-3.158 7.549.858 9.426zm-5.222-17.607c-2.826.114-5.132 3.079-4.81 5.531 2.612.203 5.118-2.725 4.81-5.531z"/></svg>
            macOS
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 12v-8.646l10-1.355v10.001h-10zm11 0h13v-12l-13 1.807v10.193zm-1 1h-10v7.646l10 1.355v-9.001zm1 0v9.194l13 1.806v-11h-13z"/></svg>
            Windows
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.311.015-.466.046a3.1 3.1 0 0 0-2.464 2.464 3.09 3.09 0 0 0 .793 2.807L7.89 7.793a3.084 3.084 0 0 0-2.808-.794A3.1 3.1 0 0 0 2.618 9.463c-.361 1.53.456 3.09 1.913 3.66l-1.48 5.554a3.097 3.097 0 0 0 2.174 3.79 3.1 3.1 0 0 0 3.79-2.175l1.481-5.554a3.091 3.091 0 0 0 2.808.794 3.1 3.1 0 0 0 2.464-2.464 3.09 3.09 0 0 0-.794-2.808l2.477-2.477a3.084 3.084 0 0 0 2.808.794 3.1 3.1 0 0 0 2.464-2.464c.362-1.53-.456-3.09-1.913-3.66.023-.154.035-.31.035-.466A3.1 3.1 0 0 0 18.496 0a3.1 3.1 0 0 0-3.1 3.1c0 .155.012.31.035.465L12.954.534A3.1 3.1 0 0 0 12.504 0z"/></svg>
            Linux
          </span>
        </div>
      </div>

      <!-- Right: animated TOTP mockup -->
      <div class="animate-fade-in delay-3 hidden lg:flex justify-center" style="animation: float-slow 8s ease-in-out infinite;">
        <div class="relative">
          <!-- Phone/app frame -->
          <div class="w-[280px] rounded-3xl border border-border bg-surface p-4 shadow-2xl shadow-black/40">
            <!-- Status bar -->
            <div class="flex items-center justify-between mb-6 px-1">
              <span class="text-[10px] font-mono text-fg-subtle">Yhtua</span>
              <div class="flex gap-1">
                <div class="w-1 h-1 rounded-full bg-emerald"></div>
                <span class="text-[10px] font-mono text-emerald">Encrypted</span>
              </div>
            </div>

            <!-- Token card 1 — active with ring -->
            <div class="bg-elevated rounded-2xl p-4 mb-3 border border-amber/10">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 rounded-xl bg-amber-glow-strong flex items-center justify-center">
                  <span class="text-xs font-bold text-amber">GH</span>
                </div>
                <div class="flex-1">
                  <span class="text-[13px] font-semibold text-fg block">GitHub</span>
                  <span class="text-[10px] text-fg-subtle font-mono">6-digit · 30s</span>
                </div>
                <!-- Mini countdown ring -->
                <svg class="w-8 h-8 -rotate-90" viewBox="0 0 36 36">
                  <circle cx="18" cy="18" r="15" fill="none" stroke-width="2" class="stroke-border" />
                  <circle cx="18" cy="18" r="15" fill="none" stroke-width="2" stroke-linecap="round" class="stroke-amber" style="stroke-dasharray: 94.248; animation: ring-countdown 30s linear infinite;" />
                </svg>
              </div>
              <!-- Animated digits -->
              <div class="flex items-center justify-center gap-1.5">
                <span class="totp-digit" style="animation: digit-flip 30s ease-in-out infinite;">4</span>
                <span class="totp-digit" style="animation: digit-flip 30s ease-in-out infinite 0.3s;">8</span>
                <span class="totp-digit" style="animation: digit-flip 30s ease-in-out infinite 0.5s;">3</span>
                <span class="w-2"></span>
                <span class="totp-digit" style="animation: digit-flip 30s ease-in-out infinite 0.7s;">9</span>
                <span class="totp-digit" style="animation: digit-flip 30s ease-in-out infinite 0.9s;">2</span>
                <span class="totp-digit" style="animation: digit-flip 30s ease-in-out infinite 1.1s;">7</span>
              </div>
            </div>

            <!-- Token card 2 — inactive -->
            <div class="bg-elevated rounded-2xl p-3 mb-2 border border-border">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-emerald-glow flex items-center justify-center">
                  <span class="text-[10px] font-bold text-emerald">GL</span>
                </div>
                <span class="text-[13px] font-medium text-fg">GitLab</span>
                <svg class="w-3.5 h-3.5 text-fg-subtle ml-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
              </div>
            </div>

            <!-- Token card 3 — inactive -->
            <div class="bg-elevated rounded-2xl p-3 mb-2 border border-border">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-sky-500/10 flex items-center justify-center">
                  <span class="text-[10px] font-bold text-sky-400">AWS</span>
                </div>
                <span class="text-[13px] font-medium text-fg">AWS Console</span>
                <svg class="w-3.5 h-3.5 text-fg-subtle ml-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
              </div>
            </div>

            <!-- Token card 4 — inactive -->
            <div class="bg-elevated rounded-2xl p-3 border border-border">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center">
                  <span class="text-[10px] font-bold text-rose-400">GC</span>
                </div>
                <span class="text-[13px] font-medium text-fg">Google Cloud</span>
                <svg class="w-3.5 h-3.5 text-fg-subtle ml-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
              </div>
            </div>
          </div>

          <!-- Glow behind -->
          <div class="absolute -inset-8 -z-10 rounded-3xl opacity-40" style="background: radial-gradient(circle, rgba(212,165,74,0.1) 0%, transparent 70%);"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features — horizontal cards, not grid -->
  <section id="features" class="relative py-28 border-t border-border">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-14 animate-fade-in">
        <p class="text-[13px] font-bold tracking-widest uppercase text-amber mb-3">Features</p>
        <h2 class="text-3xl md:text-[2.5rem] font-extrabold tracking-[-0.02em] leading-[1.1]">
          <span class="text-fg">Everything you need,</span><br />
          <span class="text-fg-muted">nothing you don't.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-3">
        <div class="group rounded-2xl border border-border bg-surface p-5 hover:bg-elevated hover:border-border-hover transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-amber-glow border border-amber/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-amber" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-fg mb-1">AES-256 Encryption</h3>
              <p class="text-[13px] text-fg-muted leading-relaxed">Every secret encrypted at rest with AES-256-GCM. Keys live in your OS keychain — never on disk in plaintext.</p>
            </div>
          </div>
        </div>

        <div class="group rounded-2xl border border-border bg-surface p-5 hover:bg-elevated hover:border-border-hover transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-emerald-glow border border-emerald/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-emerald" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
              </svg>
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-fg mb-1">Cross-Device Sync</h3>
              <p class="text-[13px] text-fg-muted leading-relaxed">Sync via any cloud folder. Password-protected backups with PBKDF2 key derivation at 600,000 iterations.</p>
            </div>
          </div>
        </div>

        <div class="group rounded-2xl border border-border bg-surface p-5 hover:bg-elevated hover:border-border-hover transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-sky-500/8 border border-sky-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
              </svg>
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-fg mb-1">Native Desktop App</h3>
              <p class="text-[13px] text-fg-muted leading-relaxed">Built with Tauri and Rust. Lightweight (~5MB), fast, and native to macOS, Windows, and Linux.</p>
            </div>
          </div>
        </div>

        <div class="group rounded-2xl border border-border bg-surface p-5 hover:bg-elevated hover:border-border-hover transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-rose-500/8 border border-rose-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-rose-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a48.667 48.667 0 0 0-1.418 8.773 3.752 3.752 0 0 0 3.138 4.107 3.75 3.75 0 0 0 4.244-3.143 48.094 48.094 0 0 1 1.036-6.237m.952-4.507a48.497 48.497 0 0 0-7.138-.681" />
              </svg>
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-fg mb-1">OS Keychain Integration</h3>
              <p class="text-[13px] text-fg-muted leading-relaxed">Encryption keys stored in macOS Keychain, Windows Credential Manager, or Linux Secret Service.</p>
            </div>
          </div>
        </div>

        <div class="group rounded-2xl border border-border bg-surface p-5 hover:bg-elevated hover:border-border-hover transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-fuchsia-500/8 border border-fuchsia-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-fuchsia-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />
              </svg>
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-fg mb-1">Fully Open Source</h3>
              <p class="text-[13px] text-fg-muted leading-relaxed">MIT licensed. No telemetry, no analytics, no accounts. Audit every line of code yourself.</p>
            </div>
          </div>
        </div>

        <div class="group rounded-2xl border border-border bg-surface p-5 hover:bg-elevated hover:border-border-hover transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-teal-500/8 border border-teal-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
              </svg>
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-fg mb-1">Import & Export</h3>
              <p class="text-[13px] text-fg-muted leading-relaxed">Password-encrypted backups. Migrate from other authenticators. You're never locked in.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Security — left-aligned with code -->
  <section id="security" class="relative py-28 border-t border-border">
    <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse at 80% 50%, rgba(52,211,153,0.03) 0%, transparent 50%);"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-[13px] font-bold tracking-widest uppercase text-emerald mb-3">Security</p>
          <h2 class="text-3xl md:text-[2.5rem] font-extrabold tracking-[-0.02em] leading-[1.1] mb-6">
            <span class="text-fg">Security isn't a feature.</span><br />
            <span class="text-fg-muted">It's a choice.</span>
          </h2>
          <p class="text-[15px] text-fg-muted leading-relaxed mb-8">
            Every design decision prioritizes security. Your TOTP secrets never leave your device unencrypted. No servers, no cloud accounts, no trust required.
          </p>

          <div class="space-y-3.5">
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald/10 border border-emerald/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2.5 h-2.5 text-emerald" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              </div>
              <div>
                <p class="text-[14px] font-semibold text-fg">AES-256-GCM</p>
                <p class="text-[13px] text-fg-muted mt-0.5">Authenticated encryption for all stored secrets</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald/10 border border-emerald/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2.5 h-2.5 text-emerald" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              </div>
              <div>
                <p class="text-[14px] font-semibold text-fg">PBKDF2-SHA256 · 600k iterations</p>
                <p class="text-[13px] text-fg-muted mt-0.5">Key derivation that resists brute-force attacks</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald/10 border border-emerald/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2.5 h-2.5 text-emerald" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              </div>
              <div>
